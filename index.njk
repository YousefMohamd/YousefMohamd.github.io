---
layout: layouts/home.njk
eleventyNavigation:
  key: Home
  order: 1
---

<!-- Header -->
<header class="w3-container w3-padding-32 w3-center w3-black" id="home">
  <h1 class="w3-jumbo">{{ metadata.title }}</h1>
  <p>{{ metadata.description }}</p>
  <!-- صورتك الشخصية -->
  <img src="{{ '/img/w3images/profile/myphoto.jpg' | url }}" 
       alt="{{ metadata.author.name }}" 
       style="max-width:180px;border-radius:50%;margin-top:16px;">
</header>

<!-- About -->
<div class="w3-content w3-justify w3-text-grey w3-padding-64" id="about">
  <h2 class="w3-text-light-grey">{{ metadata.author.name }}</h2>
  <hr style="width:200px" class="w3-opacity">
  <p>{{ metadata.author.summary }}</p>
</div>

<!-- Social -->
<div class="w3-content w3-justify w3-text-grey w3-padding-32" id="social">
  <h2 class="w3-text-light-grey">Find Me Online</h2>
  <hr style="width:200px" class="w3-opacity">
  <p class="w3-large">
    <a href="{{ metadata.social.linkedin }}" target="_blank" rel="noopener">
      <i class="fa fa-linkedin w3-xlarge"></i>
    </a>&nbsp;&nbsp;
    <a href="{{ metadata.social.behance }}" target="_blank" rel="noopener">
      <i class="fa fa-behance w3-xlarge"></i>
    </a>&nbsp;&nbsp;
    <a href="{{ metadata.social.instagram }}" target="_blank" rel="noopener">
      <i class="fa fa-instagram w3-xlarge"></i>
    </a>&nbsp;&nbsp;
    <a href="{{ metadata.social.vimeo }}" target="_blank" rel="noopener">
      <i class="fa fa-vimeo w3-xlarge"></i>
    </a>&nbsp;&nbsp;
    <a href="{{ metadata.social.youtube }}" target="_blank" rel="noopener">
      <i class="fa fa-youtube-play w3-xlarge"></i>
    </a>
  </p>
</div>

<!-- Portfolio placeholder -->
<div class="w3-padding-64 w3-content" id="photos">
  <h2 class="w3-text-light-grey">My Works</h2>
  <hr style="width:200px" class="w3-opacity">
  <p class="w3-text-grey">Projects coming soon.</p>
</div>

<!-- Contact -->
<div class="w3-padding-64 w3-content w3-text-grey" id="contact">
  <h2 class="w3-text-light-grey">Contact Me</h2>
  <hr style="width:200px" class="w3-opacity">
  <div class="w3-section">
    <p>
      <i class="fa fa-map-marker fa-fw w3-text-white w3-xxlarge w3-margin-right"></i> 
      {{ metadata.author.location }}
    </p>
    <p>
      <i class="fa fa-envelope fa-fw w3-text-white w3-xxlarge w3-margin-right"></i> 
      {{ metadata.author.email }}
    </p>
  </div>
</div>
